# Lore reads the API key for your chosen provider from the environment.
# Set ONE of these (or store the key with `lore config set` instead).
# Copy this file to .env only if your shell tooling loads it — Lore itself
# reads real environment variables.

# Anthropic (https://console.anthropic.com)
#ANTHROPIC_API_KEY=

# OpenAI (https://platform.openai.com)
#OPENAI_API_KEY=

# OpenRouter (https://openrouter.ai/keys)
#OPENROUTER_API_KEY=

# DeepSeek (https://platform.deepseek.com)
#DEEPSEEK_API_KEY=

# Generic key for --provider custom / any OpenAI-compatible endpoint
#LORE_API_KEY=

# Optional overrides (flags > env > ~/.lore/config.toml)
#LORE_PROVIDER=openrouter
#LORE_MODEL=deepseek/deepseek-chat-v3.1
#LORE_BASE_URL=
